{
  "name": "context-ai",
  "version": "1.0.2",
  "description": "System tray desktop app for AI-assisted text operations via global hotkey",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "npm run build:native && electron-vite dev",
    "dev:automation": "npm run build:native && REMOTE_DEBUGGING_PORT=9222 electron-vite dev -- --no-sandbox",
    "build": "npm run build:native && electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:native": "cd native && node-gyp rebuild",
    "rebuild:native": "cd native && node-gyp rebuild",
    "package": "npm run build && electron-builder --dir --config electron-builder.yml",
    "package:mac": "npm run build && electron-builder --mac --dir --config electron-builder.yml",
    "package:win": "npm run build && electron-builder --win --dir --config electron-builder.yml",
    "make": "npm run build && electron-builder --config electron-builder.yml",
    "make:mac": "npm run build && electron-builder --mac --config electron-builder.yml",
    "make:win": "npm run build && electron-builder --win --config electron-builder.yml"
  },
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "clsx": "^2.1.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "node-addon-api": "^8.7.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^7.3.1",
    "vitest": "^4.1.2"
  }
}
