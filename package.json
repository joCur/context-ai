{
  "name": "context-ai",
  "version": "0.1.0",
  "description": "System tray desktop app for AI-assisted text operations via global hotkey",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "npm run build:native && electron-vite dev",
    "build": "npm run build:native && electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:native": "cd native && node-gyp rebuild",
    "rebuild:native": "cd native && node-gyp rebuild"
  },
  "build": {
    "appId": "com.context-ai.app",
    "productName": "Context AI",
    "icon": "resources/icon.png",
    "mac": {
      "icon": "resources/icon.icns"
    },
    "win": {
      "icon": "resources/icon.ico"
    },
    "linux": {
      "icon": "resources/icon.png"
    },
    "extraResources": [
      {
        "from": "resources/icon.png",
        "to": "icon.png"
      }
    ]
  },
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "clsx": "^2.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.1.0",
    "electron-vite": "^5.0.0",
    "node-addon-api": "^8.7.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^7.3.1",
    "vitest": "^4.1.2"
  }
}
